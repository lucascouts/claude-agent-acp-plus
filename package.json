{
  "name": "@lucascouts/claude-agent-acp-plus",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.4.0",
  "description": "ACP adapter for the Claude Agent SDK with VS Code-parity UX for Zed and other ACP clients — checkbox multi-select questions, refusal consent dialog, dynamic agent name. Fork of claude-agent-acp.",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "bin": {
    "claude-agent-acp-plus": "dist/index.js"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    },
    "./*": "./*"
  },
  "files": [
    "dist/",
    "!dist/tests/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npm run build && npm run start",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check",
    "ci:local": "npm run format:check && npm run lint && npm run build && npm run test:run",
    "test": "vitest",
    "test:integration": "RUN_INTEGRATION_TESTS=true vitest run",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "acp",
    "agent",
    "anthropic",
    "typescript",
    "sdk",
    "code"
  ],
  "homepage": "https://github.com/lucascouts/claude-agent-acp-plus#readme",
  "bugs": {
    "url": "https://github.com/lucascouts/claude-agent-acp-plus/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucascouts/claude-agent-acp-plus.git"
  },
  "author": "Zed Industries",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@anthropic-ai/claude-agent-sdk": "0.3.212",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.112.1",
    "@eslint/js": "10.0.1",
    "@tsconfig/node24": "24.0.4",
    "@types/node": "26.1.1",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
